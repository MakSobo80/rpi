<Window x:Class="Notatnik.windowconfirm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notatnik"
        mc:Ignorable="d"
        Background="DarkGray"
        Title="Zatwierdzanie plików" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header buttons -->
        <Button Grid.Column="0" Grid.Row="0" Content="Zatwierdz (Pobierz)" Foreground="black"
                Background="#FFE5E5E5" BorderBrush="DarkGray"
                HorizontalAlignment="Center" Margin="0,10,0,10"
                VerticalAlignment="Center" Width="160" Height="40" Click="Zatwierdz"/>
        <Button Grid.Column="1" Grid.Row="0" Content="Odrzuc (Usuń)" Foreground="black"
                Background="#FFE5E5E5" BorderBrush="DarkGray"
                HorizontalAlignment="Center" Margin="0,10,0,10"
                VerticalAlignment="Center" Width="160" Height="40" Click="Odrzuc"/>

        <!-- File list -->
        <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Margin="10,0,10,10" Background="#FFC5C3C3">
            <Label Content="Pliki w organizacji:" FontWeight="Bold" Margin="4,4,4,0"/>
            <ListBox x:Name="listFiles" Margin="4" Height="300"
                     SelectionChanged="ListFiles_SelectionChanged"/>
        </StackPanel>

        <!-- File details -->
        <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Margin="10,0,10,10" Background="#FFC5C3C3">
            <Label Content="Szczegóły pliku:" FontWeight="Bold" Margin="4,4,4,0"/>
            <Label x:Name="labelFileName" Content="Nazwa: —" Margin="4,4,4,0"/>
            <Label x:Name="labelFileAuthor" Content="Autor: —" Margin="4,2,4,0"/>
            <Label x:Name="labelFileSize" Content="Rozmiar: —" Margin="4,2,4,0"/>
        </StackPanel>

        <!-- Back button -->
        <Button Grid.Column="1" Grid.Row="2" Content="Powrót" Width="100" Height="36"
                HorizontalAlignment="Right" Margin="10,0,10,10"
                Background="#FFE5E5E5" BorderBrush="DarkGray" Click="Powrot_Click"/>
    </Grid>
</Window>
