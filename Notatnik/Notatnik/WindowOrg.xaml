<Window x:Class="Notatnik.windoworg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Notatnik"
        mc:Ignorable="d"
        Background="DarkGray"
        Title="Zarządzanie organizacją" Height="520" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Organization info -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Organizacja:" FontWeight="Bold" Foreground="White"/>
            <Label x:Name="labelOrgName" Content="—" Foreground="White"/>
        </StackPanel>

        <!-- Manager-only rows (rename + create new org) -->
        <StackPanel Grid.Row="1" x:Name="panelManagerRows" Visibility="Collapsed" Margin="0,0,0,8">
            <!-- Rename org -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Label Content="Zmień nazwę:" Foreground="White" Width="110"/>
                <TextBox x:Name="txtRenameOrg" Width="120" Margin="5,0,0,0"/>
                <Button Content="Zmień" Width="60" Margin="5,0,0,0" Click="ZmienNazweOrg_Click"
                        Background="#FFE5E5E5" BorderBrush="DarkGray"/>
            </StackPanel>
            <!-- New org -->
            <StackPanel Orientation="Horizontal">
                <Label Content="Nowa organizacja:" Foreground="White" Width="110"/>
                <TextBox x:Name="txtNewOrgName" Width="120" Margin="5,0,0,0"/>
                <Button Content="Utwórz" Width="70" Margin="5,0,0,0" Click="UtworzOrg_Click"
                        Background="#FFE5E5E5" BorderBrush="DarkGray"/>
            </StackPanel>
        </StackPanel>

        <!-- Members list -->
        <GroupBox Grid.Row="2" Header="Członkowie" Foreground="White" Margin="0,0,0,8">
            <ListBox x:Name="listMembers" DisplayMemberPath="DisplayText" Margin="4"/>
        </GroupBox>

        <!-- Manager action buttons -->
        <StackPanel Grid.Row="3" x:Name="panelManagerButtons" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="Collapsed">
            <Button Content="Dodaj użytkownika" Width="150" Height="40" Margin="5,0"
                    Background="#FFE5E5E5" BorderBrush="DarkGray" Click="DodajUzytkownika_Click"/>
            <Button Content="Usuń z organizacji" Width="140" Height="40" Margin="5,0"
                    Background="#FFE5E5E5" BorderBrush="DarkGray" Click="UsunUzytkownika_Click"/>
            <Button Content="Zmień status managera" Width="160" Height="40" Margin="5,0"
                    Background="#FFE5E5E5" BorderBrush="DarkGray" Click="ZmienManagera_Click"/>
        </StackPanel>

        <!-- Back button -->
        <Button Grid.Row="4" Content="Powrót" Width="100" Height="36" HorizontalAlignment="Right"
                Background="#FFE5E5E5" BorderBrush="DarkGray" Click="Powrot_Click"/>
    </Grid>
</Window>
